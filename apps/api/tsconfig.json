{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "paths": {
      "@root/*": ["./*"],
      "@src/*": ["./src/*"],
      "@libs/*": ["./src/libs/*"],
      "@http/*": ["./src/http/*"],
      "@config/*": ["./src/config/*"],
      "@database/*": ["./src/database/*"],
      "@locales/*": ["./src/locales/*"],
      "@tests/*": ["./tests/*"],
      "@utils/*": ["./src/utils/*"],
      "@entities/*": ["./src/domain/entities/*"],
      "@shared/*": ["./src/shared/*"],
      "@errors/*": ["./src/errors/*"],
      "@errors": ["./src/errors/index.ts"],
      "@services/*": ["./src/services/*"]
    }
  },
  "include": ["src", "tests", "drizzle.config.ts", "eslint.config.mjs"],
  "exclude": ["node_modules"]
}

    "resend": "^6.8.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.15.6",
    "eslint": "^9.39.1",
    "pino-pretty": "^13.1.2",

# Database
DATABASE_URL #ex: postgresql://user:password@localhost:5432/condo_db

# Environment
NODE_ENV #ex: development | production | staging

# Logging
LOG_LEVEL #ex: info | debug | warn | error

# Resend (Email) - for notification processor
RESEND_API_KEY #ex: re_xxxxxxxxxxxxx
RESEND_FROM_EMAIL #ex: Condo App <noreply@resend.dev>

# App URL - used in email templates (e.g. "Ver en la plataforma" link)
APP_URL #ex: http://localhost:3000

# Internal API (for WebSocket broadcast via API server)
INTERNAL_API_URL #ex: http://localhost:9000 (API server URL)
INTERNAL_API_KEY #ex: same secret as INTERNAL_API_KEY in the API server

# Firebase - required for push notifications
FIREBASE_API_KEY #ex: your_firebase_api_key
FIREBASE_SERVICE_ACCOUNT_BASE64 #ex: base64-encoded service account JSON (required for production)

# Sentry (Error Monitoring)
SENTRY_DSN #ex: https://xxx@o123.ingest.sentry.io/456 (optional, enables error tracking)
